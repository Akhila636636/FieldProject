/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data is scoped
 * under a user's unique ID, and access is restricted to the authenticated owner of that data.
 * This ensures user data remains private and isolated.
 *
 * Data Structure: The data is organized hierarchically, with all user-specific collections
 * nested under `/users/{userId}`. This structure provides natural, path-based security and
 * enables efficient, secure queries for a user's own content.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read or write data within their own document tree
 *   (i.e., under `/users/{their-own-userId}`).
 * - No User Listing: Listing documents in the top-level `/users` collection is explicitly
 *   disallowed to prevent the enumeration of all application users.
 * - Default Deny: Any path not explicitly defined in these rules is inaccessible.
 *
 * Denormalization for Authorization: To ensure performant and secure authorization, a critical
 * design pattern is enforced: every document created under a user's path (e.g., Conversations,
 * Messages) MUST contain a denormalized `ownerId` field that matches the `{userId}` from the path.
 * This allows rules to perform fast, direct ownership checks without needing slow and costly `get()`
 * calls to parent documents.
 *
 * Structural Segregation: The entire data model uses structural segregation. By nesting all
 * private content within a user-specific path, we create a secure boundary that prevents data
 * leakage between users and simplifies rules for list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId from the path.
     * This is the primary function for establishing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies ownership for an existing document. Used for update and delete operations
     * to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * On create, validates that the incoming document's `ownerId` field is correctly
     * set to the creating user's UID. Enforces denormalization for authorization.
     */
    function hasCorrectOwnerId(userId) {
      return request.resource.data.ownerId == userId;
    }

    /**
     * On create, validates that the incoming document's `conversationId` field
     * correctly matches the parent `conversationId` from the path. Enforces
     * relational integrity.
     */
    function hasCorrectParentId(conversationId) {
      return request.resource.data.conversationId == conversationId;
    }

    /**
     * On update, ensures that critical, immutable fields like `ownerId` and
     * `conversationId` are not being changed.
     */
    function immutableFieldsAreUnchanged() {
      let ownerIsImmutable = request.resource.data.ownerId == resource.data.ownerId;
      // The conversationId field may not exist on the Conversation document itself.
      // We check for its existence before trying to compare it.
      let parentIsImmutable = !('conversationId' in resource.data) || request.resource.data.conversationId == resource.data.conversationId;
      return ownerIsImmutable && parentIsImmutable;
    }

    // --------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------

    /**
     * @description Governs access to a user's root document.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own user profile document.
     * @deny  (list) Any user attempting to list all documents in the /users collection.
     * @principle Prevents user enumeration and allows users to manage their own root document.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // --------------------------------------------------------------------
    // Conversation Rules
    // --------------------------------------------------------------------

    /**
     * @description Secures conversation documents, ensuring they are only accessible by their owner.
     * @path /users/{userId}/conversations/{conversationId}
     * @allow (create) An authenticated user creating a new conversation for themselves, with the correct `ownerId` field.
     * @deny  (update) A user trying to change the `ownerId` of an existing conversation.
     * @principle Enforces strict document ownership and immutability of the owner link.
     */
    match /users/{userId}/conversations/{conversationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerId(userId);
      allow update: if isExistingOwner(userId) && immutableFieldsAreUnchanged();
      allow delete: if isExistingOwner(userId);
    }

    // --------------------------------------------------------------------
    // Sub-Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description Secures chat messages within a conversation.
     * @path /users/{userId}/conversations/{conversationId}/messages/{messageId}
     * @allow (create) The conversation owner creating a message that correctly links back to its parent conversation and owner.
     * @deny  (create) The conversation owner creating a message with a mismatched `conversationId`.
     * @principle Enforces ownership and validates relational integrity between a child (Message) and parent (Conversation) document.
     */
    match /users/{userId}/conversations/{conversationId}/messages/{messageId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerId(userId) && hasCorrectParentId(conversationId);
      allow update: if isExistingOwner(userId) && immutableFieldsAreUnchanged();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures AI-generated profile summaries linked to a conversation.
     * @path /users/{userId}/conversations/{conversationId}/profileSummaries/{profileSummaryId}
     * @allow (get) The conversation owner retrieving a profile summary associated with their conversation.
     * @deny  (update) Any user other than the owner trying to modify a summary.
     * @principle Enforces ownership and validates relational integrity between a child (Summary) and parent (Conversation) document.
     */
    match /users/{userId}/conversations/{conversationId}/profileSummaries/{profileSummaryId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerId(userId) && hasCorrectParentId(conversationId);
      allow update: if isExistingOwner(userId) && immutableFieldsAreUnchanged();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures AI-generated project recommendations linked to a conversation.
     * @path /users/{userId}/conversations/{conversationId}/projectRecommendations/{projectRecommendationId}
     * @allow (list) The conversation owner listing all project recommendations for one of their conversations.
     * @deny  (delete) A different user trying to delete a recommendation from another user's conversation.
     * @principle Enforces ownership and validates relational integrity between a child (Recommendation) and parent (Conversation) document.
     */
    match /users/{userId}/conversations/{conversationId}/projectRecommendations/{projectRecommendationId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && hasCorrectOwnerId(userId) && hasCorrectParentId(conversationId);
      allow update: if isExistingOwner(userId) && immutableFieldsAreUnchanged();
      allow delete: if isExistingOwner(userId);
    }
  }
}
