
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Rules for user-specific data nested under /users/{userId}
    // This covers chat messages, and specific conversation data.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Rules for collection group queries.
    // These need to be separate to allow 'list' operations across all conversations for a user.
    // The actual security is enforced by the 'where("ownerId", "==", userId)' clause in the client query.
    
    match /{path=**}/profileSummaries/{summaryId} {
      // Allow a user to list summaries they own.
      allow list: if request.auth != null;
      // Allow a user to get a specific summary if they own it.
      allow get: if isOwner(resource.data.ownerId);
    }
    
    match /{path=**}/projectRecommendations/{recommendationId} {
      // Allow a user to list recommendations they own.
      allow list: if request.auth != null;
       // Allow a user to get a specific recommendation if they own it.
      allow get: if isOwner(resource.data.ownerId);
    }
  }
}
