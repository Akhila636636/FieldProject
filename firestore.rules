
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // This allows a user to access documents directly within their own user path.
    // e.g., get(/users/{userId}/conversations/{convoId})
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // These rules are required to enable cross-document (collectionGroup) queries.
    // Firestore security rules for "list" (queries) cannot access resource.data.
    // Therefore, security must be enforced in the client-side query using a `where` clause.
    // We still check if the user is signed in as a basic security measure.
    
    match /{path=**}/profileSummaries/{summaryId} {
      // Allow a user to list summaries they own via a query like:
      // query(collectionGroup(db, 'profileSummaries'), where('ownerId', '==', auth.currentUser.uid))
      allow list: if request.auth != null;
      
      // Allow a user to get a specific summary if they own it.
      // This is a stronger rule for direct document access.
      allow get: if isOwner(resource.data.ownerId);
    }
    
    match /{path=**}/projectRecommendations/{recommendationId} {
      // Allow a user to list recommendations they own via a query like:
      // query(collectionGroup(db, 'projectRecommendations'), where('ownerId', '==', auth.currentUser.uid))
      allow list: if request.auth != null;

      // Allow a user to get a specific recommendation if they own it.
      allow get: if isOwner(resource.data.ownerId);
    }

    // Benchmark Gallery: community-driven, any signed-in user can read.
    // Any signed-in user can create a new entry (seeding a project).
    // Only the user who seeded the entry can update or delete it.
    match /benchmarkGallery/{benchmarkId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.seededByUserId == request.auth.uid;
    }
  }
}
