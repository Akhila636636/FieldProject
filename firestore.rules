
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows any authenticated user to read and write any document.
    // This is a common and secure approach for development environments, as it
    // still requires users to be logged in. For production, you would likely
    // implement more granular, path-based rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
